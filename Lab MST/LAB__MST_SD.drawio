        <mxCell id="LQCjEl2z3Vptmbs0Bkn--1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Design an Instagram like system with following requirements:&lt;br&gt;1: User Login Service&lt;br&gt;2: Content Service&lt;br&gt;3: Feed Service&lt;br&gt;4: Follower Service&lt;br&gt;5: User Engagement Service&lt;br&gt;Implement a mechanism to restrict the user for posting a non-policy compliant post.&lt;br&gt;Optimize the dynamic feed generation for the users.&lt;br&gt;Highlight the use of Back-Fill service.&lt;/font&gt;&lt;/h3&gt;" vertex="1">
          <mxGeometry height="190" width="630" x="40" y="20" as="geometry" />
        </mxCell>
